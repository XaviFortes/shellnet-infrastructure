# /etc/haproxy/haproxy.cfg — managed by Ansible
# Edge node: {{ inventory_hostname }} ({{ ovh_gra_zone }})

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user {{ haproxy_user }}
    group {{ haproxy_group }}
    daemon

    # TLS hardening
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
    ssl-default-bind-options prefer-client-ciphers no-sslv3 no-tlsv10 no-tlsv11 no-tls-tickets
    ssl-default-server-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384
    ssl-default-server-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
    ssl-default-server-options no-sslv3 no-tlsv10 no-tlsv11 no-tls-tickets

defaults
    log global
    mode http
    option httplog
    option dontlognull
    option forwardfor
    option http-server-close
    timeout connect 5s
    timeout client  30s
    timeout server  30s
    errorfile 400 /etc/haproxy/errors/400.http
    errorfile 403 /etc/haproxy/errors/403.http
    errorfile 408 /etc/haproxy/errors/408.http
    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

{% if haproxy_stats_enabled %}
# ── Stats ─────────────────────────────────────────────────────────────────────
frontend stats
    bind *:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri {{ haproxy_stats_uri }}
    stats refresh 10s
    stats auth admin:{{ vault_haproxy_stats_password }}
    stats hide-version
{% endif %}

# ── HTTP → HTTPS redirect ─────────────────────────────────────────────────────
frontend http_front
    bind *:80
    mode http
    redirect scheme https code 301 if !{ ssl_fc }

# ── HTTPS passthrough to K3s ingress (MAD1) ───────────────────────────────────
frontend https_front
    bind *:443 ssl crt /etc/letsencrypt/live/{{ certbot_domains[0] | default('localhost') }}/fullchain.pem alpn h2,http/1.1
    mode http
    default_backend k3s_ingress

backend k3s_ingress
    mode http
    balance roundrobin
    option httpchk GET /healthz
    {% for host in groups['ovh_k3s'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:443 check ssl verify none
    {% endfor %}

# ── Kubernetes API passthrough ────────────────────────────────────────────────
frontend kubeadm_api
    bind *:6443
    mode tcp
    default_backend kubeadm_api_back

backend kubeadm_api_back
    mode tcp
    balance roundrobin
    option tcp-check
    # Backends defined per-environment in group_vars

# ── WireGuard UDP passthrough ─────────────────────────────────────────────────
# WireGuard is handled by the kernel directly on port {{ wireguard_listen_port }}
# No HAProxy frontend needed — kernel handles UDP natively.

# ── Minecraft TCP frontends ───────────────────────────────────────────────────
frontend minecraft_main
    bind *:25565
    mode tcp
    default_backend minecraft_main_back

backend minecraft_main_back
    mode tcp
    # server minecraft-main <homelab-ip>:25565

frontend minecraft_uhc
    bind *:25566
    mode tcp
    default_backend minecraft_uhc_back

backend minecraft_uhc_back
    mode tcp
    # server minecraft-uhc <homelab-ip>:25566
