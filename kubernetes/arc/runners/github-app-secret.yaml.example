---
# kubernetes/arc/runners/github-app-secret.yaml
# PLACEHOLDER — do NOT apply this file directly.
# The actual secret is created by Ansible (see ansible/roles/arc-secret/),
# which reads the values from the SOPS vault and writes them to K3s.
#
# This file documents the expected shape of the secret so it is clear
# what Ansible must produce. It is excluded from ArgoCD sync intentionally.
#
# Required fields:
#   github_app_id          — numeric App ID from GitHub App settings
#   github_app_installation_id — numeric Installation ID (your account install)
#   github_app_private_key — full PEM content of the generated private key
#
apiVersion: v1
kind: Secret
metadata:
  name: arc-github-app-secret
  namespace: arc-runners
type: Opaque
stringData:
  github_app_id: "PLACEHOLDER"
  github_app_installation_id: "PLACEHOLDER"
  github_app_private_key: |
    -----BEGIN RSA PRIVATE KEY-----
    PLACEHOLDER
    -----END RSA PRIVATE KEY-----
