#!/usr/bin/env bash
# run — unified plan/apply wrapper for all homelab IaC tools.
#
# USAGE
#   ./run <tool> plan  [options]   — show what would change, touch nothing
#   ./run <tool> apply [options]   — apply changes (always shows plan first)
#
# TOOLS
#   ansible   <playbook> [--limit host] [--tags t] [--extra-vars k=v ...]
#   kubectl   <manifest-or-dir>
#   tofu      [stack-path]              (default: all stacks via terragrunt run --all)
#   helm      <release> <chart> [--namespace ns] [--values file] [--set k=v]
#
# EXAMPLES
#   ./run ansible plan  ansible/playbooks/arc-secret.yml --limit vps-6b58f204
#   ./run ansible apply ansible/playbooks/arc-secret.yml --limit vps-6b58f204
#
#   ./run kubectl plan  kubernetes/arc/controller/argocd-app.yaml
#   ./run kubectl apply kubernetes/arc/
#
#   ./run tofu   plan  infrastructure/tofu/live/ovh/vps
#   ./run tofu   apply                                    # all stacks
#
#   ./run helm   plan  arc-controller \
#                      actions-runner-controller/gha-runner-scale-set-controller \
#                      --namespace arc-systems \
#                      --values kubernetes/arc/controller/values.yaml
#   ./run helm   apply arc-controller \
#                      actions-runner-controller/gha-runner-scale-set-controller \
#                      --namespace arc-systems

set -euo pipefail

# ── Colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${CYAN}${BOLD}==>${RESET} $*"; }
success() { echo -e "${GREEN}${BOLD}✔${RESET}  $*"; }
warn()    { echo -e "${YELLOW}${BOLD}!${RESET}  $*"; }
fatal()   { echo -e "${RED}${BOLD}✘${RESET}  $*" >&2; exit 1; }

# ── SOPS age key — ensure it's available to all subprocesses ─────────────────
# Needed by Ansible (community.sops vars plugin) and sops CLI calls.
# Set SOPS_AGE_KEY_FILE in your shell, or we fall back to the default location.
if [[ -z "${SOPS_AGE_KEY_FILE:-}" ]]; then
    _default_age="$HOME/.config/sops/age/keys.txt"
    if [[ -f "$_default_age" ]]; then
        export SOPS_AGE_KEY_FILE="$_default_age"
        info "SOPS_AGE_KEY_FILE not set — using ${_default_age}"
    else
        warn "SOPS_AGE_KEY_FILE is not set and ${_default_age} does not exist. SOPS decryption will fail."
    fi
fi
# community.sops vars plugin must run at 'task' stage so vault vars are
# available during playbook execution (not only during ansible-inventory calls).
export ANSIBLE_VARS_SOPS_PLUGIN_STAGE=task

confirm_apply() {
  echo ""
  warn "You are about to APPLY the changes shown above."
  read -r -p "    Continue? [y/N] " _confirm
  [[ "$_confirm" =~ ^[yY]$ ]] || { info "Aborted."; exit 0; }
  echo ""
}

# ── Argument parsing ──────────────────────────────────────────────────────────

TOOL="${1:-}"; ACTION="${2:-}"
[[ -z "$TOOL" || -z "$ACTION" ]] && {
  sed -n '2,30p' "$0" | grep '^#' | sed 's/^# \?//'
  exit 1
}
[[ "$ACTION" != "plan" && "$ACTION" != "apply" ]] && \
  fatal "Action must be 'plan' or 'apply', got: $ACTION"

shift 2   # remaining args passed to the tool

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"

# ── ANSIBLE ───────────────────────────────────────────────────────────────────

run_ansible() {
  local playbook="${1:-}"; shift || true
  [[ -z "$playbook" ]] && fatal "Usage: ./run ansible <plan|apply> <playbook> [ansible-playbook args...]"

  # Resolve playbook to an absolute path before cd-ing into ansible/
  local abs_playbook
  abs_playbook="$(cd "$(dirname "$playbook")" 2>/dev/null && pwd)/$(basename "$playbook")" \
    || fatal "Playbook not found: $playbook"
  [[ ! -f "$abs_playbook" ]] && fatal "Playbook not found: $playbook"

  # Always run from ansible/ so ansible.cfg is picked up (roles_path, vars_plugins, etc.)
  local ansible_dir="${REPO_ROOT}/ansible"

  # Detect inventory: prefer explicit -i arg, else auto-detect from playbook path
  local inv_arg=""
  local has_inventory=false
  for arg in "$@"; do
    [[ "$arg" == "-i" || "$arg" == "--inventory" ]] && has_inventory=true && break
  done

  if ! $has_inventory; then
    if [[ "$abs_playbook" == *"ovh-gra"* ]]; then
      inv_arg="-i inventories/ovh-gra/"
    elif [[ "$abs_playbook" == *"/ovh/"* || "$abs_playbook" == *"ovh"* ]]; then
      inv_arg="-i inventories/ovh/"
    elif [[ "$abs_playbook" == *"/almond/"* ]]; then
      inv_arg="-i inventories/almond/"
    elif [[ "$abs_playbook" == *"/peanut/"* ]]; then
      inv_arg="-i inventories/peanut/"
    else
      inv_arg="-i inventories/ovh/ -i inventories/almond/ -i inventories/peanut/ -i inventories/ovh-gra/"
    fi
    info "Auto-detected inventory: ${inv_arg}"
  fi

  info "Working directory: ${ansible_dir}"

  if [[ "$ACTION" == "plan" ]]; then
    info "Ansible CHECK (--check --diff) — no changes will be made"
    echo ""
    # shellcheck disable=SC2086
    (cd "$ansible_dir" && ansible-playbook $inv_arg --check --diff "$abs_playbook" "$@")
    echo ""
    success "Plan complete. Run './run ansible apply $playbook $*' to apply."

  else
    info "Ansible CHECK (--check --diff) — reviewing changes first..."
    echo ""
    # shellcheck disable=SC2086
    (cd "$ansible_dir" && ansible-playbook $inv_arg --check --diff "$abs_playbook" "$@") || {
      warn "Check run had failures — review above before proceeding."
    }
    confirm_apply
    info "Ansible APPLY"
    echo ""
    # shellcheck disable=SC2086
    (cd "$ansible_dir" && ansible-playbook $inv_arg "$abs_playbook" "$@")
    echo ""
    success "Apply complete."
  fi
}

# ── KUBECTL ───────────────────────────────────────────────────────────────────

run_kubectl() {
  local target="${1:-}"; shift || true
  [[ -z "$target" ]] && fatal "Usage: ./run kubectl <plan|apply> <manifest-or-dir> [kubectl args...]"

  local ctx
  ctx="$(kubectl config current-context 2>/dev/null || echo 'unknown')"
  info "kubectl context: ${BOLD}${ctx}${RESET}"

  if [[ "$ACTION" == "plan" ]]; then
    info "kubectl DIFF (--dry-run=server) — no changes will be made"
    echo ""
    kubectl diff -f "$target" "$@" || true   # diff exits 1 when there are changes — that's fine
    echo ""
    success "Plan complete. Run './run kubectl apply $target' to apply."

  else
    info "kubectl DIFF — reviewing changes first..."
    echo ""
    kubectl diff -f "$target" "$@" || true
    confirm_apply
    info "kubectl APPLY"
    echo ""
    kubectl apply -f "$target" "$@"
    echo ""
    success "Apply complete."
  fi
}

# ── TOFU / TERRAGRUNT ─────────────────────────────────────────────────────────

run_tofu() {
  local stack="${1:-}"; shift || true

  if [[ -n "$stack" ]]; then
    # Single stack
    [[ ! -d "$stack" ]] && fatal "Stack directory not found: $stack"
    info "tofu context: single stack — ${stack}"

    if [[ "$ACTION" == "plan" ]]; then
      info "Terragrunt PLAN"
      echo ""
      (cd "$stack" && terragrunt plan "$@")
      echo ""
      success "Plan complete. Run './run tofu apply $stack' to apply."

    else
      info "Terragrunt PLAN — reviewing changes first..."
      echo ""
      (cd "$stack" && terragrunt plan "$@")
      confirm_apply
      info "Terragrunt APPLY"
      echo ""
      (cd "$stack" && terragrunt apply --auto-approve "$@")
      echo ""
      success "Apply complete."
    fi

  else
    # All stacks via run --all
    info "tofu context: ALL stacks (terragrunt run --all)"

    if [[ "$ACTION" == "plan" ]]; then
      info "Terragrunt run --all plan"
      echo ""
      (cd "${REPO_ROOT}/infrastructure/tofu/live" && \
        terragrunt run --all plan --non-interactive "$@")
      echo ""
      success "Plan complete. Run './run tofu apply' to apply all stacks."

    else
      info "Terragrunt run --all plan — reviewing changes first..."
      echo ""
      (cd "${REPO_ROOT}/infrastructure/tofu/live" && \
        terragrunt run --all plan --non-interactive "$@")
      confirm_apply
      info "Terragrunt run --all apply"
      echo ""
      (cd "${REPO_ROOT}/infrastructure/tofu/live" && \
        terragrunt run --all apply --non-interactive --auto-approve "$@")
      echo ""
      success "Apply complete."
    fi
  fi
}

# ── HELM ─────────────────────────────────────────────────────────────────────

run_helm() {
  local release="${1:-}"; local chart="${2:-}"
  [[ -z "$release" || -z "$chart" ]] && \
    fatal "Usage: ./run helm <plan|apply> <release-name> <chart> [--namespace ns] [--values file] [--set k=v]"
  shift 2

  # Extract --namespace if provided, default to current namespace
  local ns="default"
  local helm_args=()
  local i=0
  local passed_args=("$@")
  while [[ $i -lt ${#passed_args[@]} ]]; do
    if [[ "${passed_args[$i]}" == "--namespace" || "${passed_args[$i]}" == "-n" ]]; then
      ns="${passed_args[$((i+1))]}"
      helm_args+=("--namespace" "$ns")
      i=$((i+2))
    else
      helm_args+=("${passed_args[$i]}")
      i=$((i+1))
    fi
  done

  local ctx
  ctx="$(kubectl config current-context 2>/dev/null || echo 'unknown')"
  info "kubectl context: ${BOLD}${ctx}${RESET}"
  info "Helm release:    ${BOLD}${release}${RESET}  chart: ${chart}  namespace: ${ns}"

  if [[ "$ACTION" == "plan" ]]; then
    info "helm diff — showing what would change"
    echo ""
    helm diff upgrade --install "$release" "$chart" \
      --namespace "$ns" --create-namespace \
      "${helm_args[@]}"
    echo ""
    success "Plan complete. Run './run helm apply $release $chart ${*}' to apply."

  else
    info "helm diff — reviewing changes first..."
    echo ""
    helm diff upgrade --install "$release" "$chart" \
      --namespace "$ns" --create-namespace \
      "${helm_args[@]}" || true
    confirm_apply
    info "helm upgrade --install"
    echo ""
    helm upgrade --install "$release" "$chart" \
      --namespace "$ns" --create-namespace \
      "${helm_args[@]}"
    echo ""
    success "Apply complete."
  fi
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

case "$TOOL" in
  ansible)  run_ansible "$@" ;;
  kubectl)  run_kubectl "$@" ;;
  tofu|terraform|terragrunt) run_tofu "$@" ;;
  helm)     run_helm    "$@" ;;
  *)
    fatal "Unknown tool: $TOOL. Valid tools: ansible, kubectl, tofu, helm"
    ;;
esac
